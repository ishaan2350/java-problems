class Point {
    int x, y;

    Point(int x, int y) {
        this.x = x;
        this.y = y;
    }
}

class Line implements Comparable<Line> {
    Point p1, p2;

    Line(Point p1, Point p2) {
        this.p1 = p1;
        this.p2 = p2;
    }

    double length() {
        return Math.sqrt(Math.pow(p2.x - p1.x, 2) +
                         Math.pow(p2.y - p1.y, 2));
    }

    @Override
    public boolean equals(Object obj) {
        Line l = (Line) obj;
        return this.length() == l.length();
    }

    @Override
    public int compareTo(Line l) {
        return Double.compare(this.length(), l.length());
    }
}

public class UC4_LineOOP {
    public static void main(String[] args) {

        Line l1 = new Line(new Point(0, 0), new Point(3, 4));
        Line l2 = new Line(new Point(0, 0), new Point(6, 8));

        System.out.println("Length1: " + l1.length());
        System.out.println("Length2: " + l2.length());

        System.out.println("Equal: " + l1.equals(l2));

        int res = l1.compareTo(l2);
        System.out.println("Compare result: " + res);
    }
}
