public class UC5_Monthly {
    public static void main(String[] args) {

        int wage = 20, full = 8, part = 4;
        int total = 0;

        for (int i = 1; i <= 20; i++) {

            int check = (int)(Math.random() * 3);
            int hours = 0;

            if (check == 1) hours = full;
            else if (check == 2) hours = part;

            total += hours * wage;
        }

        System.out.println("Monthly Salary: " + total);
    }
}
